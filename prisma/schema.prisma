generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Question {
  id              String      @id @default(uuid()) @db.Uuid
  block           Int         @db.SmallInt
  topic           String
  type            String
  question        String
  options         Json
  correct_index   Int         @db.SmallInt
  explanation     String
  topic_summary   String?
  further_reading Json        @default("[]")
  source          String      @default("hardcoded")
  created_at      DateTime    @default(now()) @db.Timestamptz

  answer_logs     AnswerLog[]

  @@map("questions")
}

model Profile {
  id              String       @id
  display_name    String
  role            String       @default("student")
  quiz_strictness String       @default("balanced")
  question_mode   String       @default("mixed")

  answer_logs          AnswerLog[]
  topic_stats          TopicStats[]
  question_generations QuestionGeneration[]
  notifications        Notification[]

  @@map("profiles")
}

model QuestionGeneration {
  id           String   @id @default(uuid()) @db.Uuid
  user_id      String
  block        Int      @db.SmallInt
  topic        String?
  count        Int      @default(0)
  generated_at DateTime @default(now()) @db.Timestamptz

  profile      Profile  @relation(fields: [user_id], references: [id])

  @@map("question_generations")
}

model Notification {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String
  title      String
  message    String
  type       String   @default("info")
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz

  profile    Profile  @relation(fields: [user_id], references: [id])

  @@map("notifications")
}

// NOTE: Before running this migration, truncate existing answer_log and topic_stats
// tables in Supabase SQL editor:
//   truncate table answer_log restart identity cascade;
//   truncate table topic_stats restart identity cascade;
// This is needed because user_id is now non-nullable.
model AnswerLog {
  id          String   @id @default(uuid()) @db.Uuid
  question_id String   @db.Uuid
  block       Int      @db.SmallInt
  topic       String
  is_correct  Boolean
  answered_at DateTime @default(now()) @db.Timestamptz
  user_id     String

  question    Question @relation(fields: [question_id], references: [id])
  profile     Profile  @relation(fields: [user_id], references: [id])

  @@map("answer_log")
}

model TopicStats {
  topic          String
  block          Int       @db.SmallInt
  total_answers  Int       @default(0)
  correct        Int       @default(0)
  last_seen      DateTime? @db.Timestamptz
  weakness_score Float     @default(0.5)
  user_id        String

  profile        Profile   @relation(fields: [user_id], references: [id])

  @@id([topic, user_id])
  @@map("topic_stats")
}
